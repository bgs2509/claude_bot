# ─── Обязательные ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here

# ─── Хранилище сессий ────────────────────────────────────────
SESSIONS_FILE=data/sessions.json

# ─── Пользователи ────────────────────────────────────────────
# Формат: JSON с Telegram user ID как ключ
# role: admin | user | readonly
# limit: 0 = безлимит, >0 = сообщений в день
# projects_dir: обязательное поле — директория проектов юзера
# model: модель Claude (haiku, sonnet, opus)
USERS={"123456789": {"role": "admin", "limit": 0, "name": "Admin", "model": "opus", "projects_dir": "/home/bgs/Henry_Bud_GitHub"}, "987654321": {"role": "user", "limit": 0, "name": "Gena_MTS", "model": "haiku", "projects_dir": "/home/bgs/_Gena_MTS"}}

# ─── Голос ────────────────────────────────────────────────────
WHISPER_MODEL=small
# Варианты: tiny (~200MB RAM), base (~500MB), small (~1GB)
WHISPER_DEVICE=cuda
# Варианты: cuda, cpu

# Варианты: ru-RU-DmitryNeural (муж), ru-RU-SvetlanaNeural (жен)
# TTS_VOICE=ru-RU-DmitryNeural
TTS_VOICE=ru-RU-SvetlanaNeural

# ─── Claude Code ──────────────────────────────────────────────
# Таймаут в секундах (600 = 10 минут)
CLAUDE_TIMEOUT=600

# Максимальный размер файла в байтах (20971520 = 20MB)
MAX_UPLOAD_SIZE=20971520


# ─── Логирование ─────────────────────────────────────────────
# Путь к файлу логов (JSON с ротацией)
# LOG_FILE=data/bot.log
# Макс. размер файла лога в байтах (10485760 = 10MB)
# LOG_MAX_BYTES=10485760
# Количество ротируемых файлов
# LOG_BACKUP_COUNT=5

# ─── Аналитика ───────────────────────────────────────────────
# Путь к SQLite базе аналитики
# ANALYTICS_DB=data/analytics.db
# Хранить записи N дней (старые удаляются автоматически)
# ANALYTICS_RETENTION_DAYS=90

# ─── Sentry (опционально) ────────────────────────────────────
# DSN для отправки ошибок в Sentry (пустая строка = отключено)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── MCP серверы (API ключи) ─────────────────────────────────
# GitHub Personal Access Token (для MCP github)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Brave Search API Key (бесплатно: brave.com/search/api)
# BRAVE_API_KEY=BSA...
