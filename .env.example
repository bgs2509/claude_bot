# ─── Обязательные ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF-your-token-here

# ─── Проекты ─────────────────────────────────────────────────
PROJECTS_DIR=/home/claude/projects

# ─── Пользователи ────────────────────────────────────────────
# Формат: JSON с Telegram user ID как ключ
# role: admin | user | readonly
# limit: 0 = безлимит, >0 = сообщений в день
# Если USERS пустой — доступ всем (режим разработки)
USERS={"123456789": {"role": "admin", "limit": 0, "name": "Admin"}, "987654321": {"role": "user", "limit": 50, "name": "User"}}

# ─── Голос ────────────────────────────────────────────────────
WHISPER_MODEL=small
# Варианты: tiny (~200MB RAM), base (~500MB), small (~1GB)
WHISPER_DEVICE=cuda
# Варианты: cuda, cpu

TTS_VOICE=ru-RU-DmitryNeural
# Варианты: ru-RU-DmitryNeural (муж), ru-RU-SvetlanaNeural (жен)

# ─── AI провайдеры ────────────────────────────────────────────
DEFAULT_PROVIDER=claude
# Варианты: claude, codex

ENABLED_PROVIDERS=claude,codex
# Список включённых провайдеров через запятую

CLAUDE_BIN=claude
CODEX_BIN=codex

# ─── Claude Code ──────────────────────────────────────────────
CLAUDE_TIMEOUT=600
# Таймаут в секундах (600 = 10 минут)

# ─── Codex ────────────────────────────────────────────────────
CODEX_TIMEOUT=600
CODEX_DEFAULT_MODEL=gpt-5.4
CODEX_MODELS=gpt-5.3-codex,gpt-5.4,gpt-5.2-codex,gpt-5.1-codex-max,gpt-5.2,gpt-5.1-codex-mini
# Список моделей Codex через запятую
CODEX_DEFAULT_REASONING_EFFORT=xhigh
CODEX_REASONING_LEVELS=low,medium,high,xhigh
# Уровни reasoning для Codex

# ─── MCP серверы (API ключи) ─────────────────────────────────
# GitHub Personal Access Token (для MCP github)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Brave Search API Key (бесплатно: brave.com/search/api)
# BRAVE_API_KEY=BSA...
